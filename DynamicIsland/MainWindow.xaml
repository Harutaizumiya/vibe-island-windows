<Window x:Class="DynamicIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:DynamicIsland.UI"
        mc:Ignorable="d"
        Title="Dynamic Island"
        Width="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowWidth}"
        Height="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowHeight}"
        MinWidth="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowWidth}"
        MinHeight="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowHeight}"
        MaxWidth="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowWidth}"
        MaxHeight="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowHeight}"
        d:DesignWidth="520"
        d:DesignHeight="300"
        AllowsTransparency="True"
        Background="Transparent"
        BorderThickness="0"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        SizeToContent="Manual"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="Transparent"
          MouseLeftButtonDown="RootGrid_OnMouseLeftButtonDown">
        <!-- Main island shell. Adjust size values in App.xaml's IslandLayoutConfig resource. -->
        <Border x:Name="MainSurface"
                Width="{x:Static ui:IslandLayout.CollapsedWidth}"
                Height="{x:Static ui:IslandLayout.CollapsedHeight}"
                Padding="12,6"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                BorderThickness="1"
                ClipToBounds="True"
                MouseEnter="MainSurface_OnMouseEnter"
                MouseLeave="MainSurface_OnMouseLeave"
                RenderTransformOrigin="0.5,0">
            <Border.CornerRadius>
                <Binding Source="{StaticResource IslandLayoutConfig}"
                         Path="CollapsedShellCornerRadius" />
            </Border.CornerRadius>
            <Border.Margin>
                <Binding Source="{StaticResource IslandLayoutConfig}"
                         Path="TopMarginThickness" />
            </Border.Margin>
            <Border.Background>
                <SolidColorBrush x:Name="MainSurfaceBackgroundBrush"
                                 Color="#FF000000" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush x:Name="MainSurfaceBorderBrush"
                                 Color="#FF161616" />
            </Border.BorderBrush>
            <Border.RenderTransform>
                <ScaleTransform x:Name="IslandScaleTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header row height follows IslandLayoutConfig for Hot Reload edits. -->
                    <RowDefinition Height="{Binding Source={StaticResource IslandLayoutConfig}, Path=StatusRowGridHeight}" />
                    <!-- Expanded content height is animated in MainWindow.xaml.cs -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="StatusCard"
                      Grid.Row="0"
                      Margin="0,4,0,0"
                      MouseLeftButtonDown="StatusCard_OnMouseLeftButtonDown">
                    <Grid Margin="2,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="StatusContentTranslateTransform"
                                                Y="0" />
                        </Grid.RenderTransform>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="GlyphContainer"
                                Width="24"
                                Height="24"
                                VerticalAlignment="Top"
                                Margin="0,4,0,0"
                                CornerRadius="12"
                                Background="#FF0A0A0A"
                                BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="GlyphBorderBrush"
                                                 Color="#FF181818" />
                            </Border.BorderBrush>
                            <Grid>
                                <Ellipse x:Name="StatusAccentEllipse"
                                         Width="18"
                                         Height="18"
                                         Opacity="0.14">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="StatusAccentEllipseBrush"
                                                        Color="#FF6CE1FF" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Viewbox Width="18"
                                         Height="18"
                                         Visibility="{Binding IsIdleCodexIconVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Width="24"
                                          Height="24">
                                        <Rectangle Width="24"
                                                   Height="24"
                                                   RadiusX="4.5"
                                                   RadiusY="4.5"
                                                   Fill="#FFFFFFFF" />
                                        <Path Data="M9.064 3.344a4.578 4.578 0 012.285-.312c1 .115 1.891.54 2.673 1.275.01.01.024.017.037.021a.09.09 0 00.043 0 4.55 4.55 0 013.046.275l.047.022.116.057a4.581 4.581 0 012.188 2.399c.209.51.313 1.041.315 1.595a4.24 4.24 0 01-.134 1.223.123.123 0 00.03.115c.594.607.988 1.33 1.183 2.17.289 1.425-.007 2.71-.887 3.854l-.136.166a4.548 4.548 0 01-2.201 1.388.123.123 0 00-.081.076c-.191.551-.383 1.023-.74 1.494-.9 1.187-2.222 1.846-3.711 1.838-1.187-.006-2.239-.44-3.157-1.302a.107.107 0 00-.105-.024c-.388.125-.78.143-1.204.138a4.441 4.441 0 01-1.945-.466 4.544 4.544 0 01-1.61-1.335c-.152-.202-.303-.392-.414-.617a5.81 5.81 0 01-.37-.961 4.582 4.582 0 01-.014-2.298.124.124 0 00.006-.056.085.085 0 00-.027-.048 4.467 4.467 0 01-1.034-1.651 3.896 3.896 0 01-.251-1.192 5.189 5.189 0 01.141-1.6c.337-1.112.982-1.985 1.933-2.618.212-.141.413-.251.601-.33.215-.089.43-.164.646-.227a.098.098 0 00.065-.066 4.51 4.51 0 01.829-1.615 4.535 4.535 0 011.837-1.388zm3.482 10.565a.637.637 0 000 1.272h3.636a.637.637 0 100-1.272h-3.636zM8.462 9.23a.637.637 0 00-1.106.631l1.272 2.224-1.266 2.136a.636.636 0 101.095.649l1.454-2.455a.636.636 0 00.005-.64L8.462 9.23z">
                                            <Path.Fill>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Offset="0" Color="#FFB1A7FF" />
                                                    <GradientStop Offset="0.5" Color="#FF7A9DFF" />
                                                    <GradientStop Offset="1" Color="#FF3941FF" />
                                                </LinearGradientBrush>
                                            </Path.Fill>
                                        </Path>
                                    </Grid>
                                </Viewbox>
                                <TextBlock x:Name="StatusGlyphText"
                                           Text="{Binding StatusGlyph}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code SemiBold"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsIdleCodexIconVisible}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="StatusTextPanel"
                                    Grid.Column="1"
                                    Margin="10,8,12,0"
                                    VerticalAlignment="Top">
                            <TextBlock x:Name="StatusTitleText"
                                       Text="{Binding StatusText}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13"
                                       LineHeight="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Top"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding DebugStatusText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10"
                                       Margin="0,2,0,0"
                                       FontFamily="Cascadia Code"
                                       Visibility="{Binding IsDebugMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            
                        </StackPanel>

                        <Border x:Name="StatusStatePill"
                                Grid.Column="2"
                                Margin="0,6,0,0"
                                Padding="10,4"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Right"
                                CornerRadius="10"
                                Background="#14FFFFFF"
                                BorderBrush="#22FFFFFF"
                                BorderThickness="1">
                            <TextBlock Text="{Binding CompactStatusText}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="ExpandedRegion"
                      Grid.Row="1"
                      Height="0"
                      VerticalAlignment="Top"
                      ClipToBounds="True">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ExpandedRegionTranslateTransform"
                                            Y="-10" />
                    </Grid.RenderTransform>

                    <!-- Expanded detail region sizing follows IslandLayoutConfig. -->
                    <Grid x:Name="ActionPanel"
                          MinHeight="{Binding ExpandedPanelMinHeight}"
                          Opacity="0">
                        <Grid.Margin>
                            <Binding Source="{StaticResource IslandLayoutConfig}"
                                     Path="ExpandedRegionTopSpacingThickness" />
                        </Grid.Margin>
                        <Grid Margin="2,0,2,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.RowSpan="2"
                                    Padding="10,6,10,10"
                                    Background="Transparent"
                                    Visibility="{Binding IsIdleExpandedState, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="没有正在进行中的会话，今天打算做点什么？"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="13"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel x:Name="ActionPanelHeader">
                                <StackPanel.Visibility>
                                    <Binding Path="IsDetailPanelVisible"
                                             Converter="{StaticResource BooleanToVisibilityConverter}" />
                                </StackPanel.Visibility>
                                <TextBlock Text="DATA SOURCE"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"
                                           Opacity="0.9"
                                           Visibility="{Binding IsDebugMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Border Padding="10,8"
                                        Margin="0,0,0,8"
                                        CornerRadius="12"
                                        Background="#14000000"
                                        BorderBrush="#22FFFFFF"
                                        BorderThickness="1"
                                        Visibility="{Binding IsDebugMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding DebugSourceText}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="11"
                                               FontFamily="Cascadia Code"
                                               TextWrapping="Wrap" />
                                </Border>
                                <TextBlock Text="{Binding ExpandedSectionTitle}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"
                                           Opacity="0.9" />
                                <Border Padding="10,8"
                                        Margin="0,0,0,8"
                                        CornerRadius="12"
                                        Background="#14000000"
                                        BorderBrush="#22FFFFFF"
                                        BorderThickness="1">
                                    <Grid>
                                        <TextBlock Text="{Binding ExpandedDetailText}"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12"
                                                   FontFamily="Cascadia Code"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding IsExpandedTextVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ItemsControl x:Name="ChangedFilesList"
                                                      ItemsSource="{Binding ChangedFiles}"
                                                      Visibility="{Binding IsChangedFilesVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="12"
                                                               FontFamily="Cascadia Code"
                                                               Margin="0,0,0,4"
                                                               TextWrapping="Wrap" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Border>
                                <TextBlock Text="{Binding PanelHintText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding IsDebugMode, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </StackPanel>

                            <UniformGrid x:Name="ActionButtonsPanel"
                                         Grid.Row="1"
                                         Margin="0,0,0,0"
                                         Columns="3"
                                         Opacity="0">
                                <UniformGrid.Visibility>
                                    <Binding Path="IsDetailPanelVisible"
                                             Converter="{StaticResource BooleanToVisibilityConverter}" />
                                </UniformGrid.Visibility>
                                <Button Command="{Binding PrimaryActionCommand}"
                                        Content="{Binding PrimaryActionText}"
                                        Style="{StaticResource AccentActionButtonStyle}"
                                        Visibility="{Binding IsPrimaryActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Command="{Binding SecondaryActionCommand}"
                                        Content="{Binding SecondaryActionText}"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Visibility="{Binding IsSecondaryActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Command="{Binding TertiaryActionCommand}"
                                        Content="{Binding TertiaryActionText}"
                                        Style="{StaticResource TertiaryActionButtonStyle}"
                                        Visibility="{Binding IsTertiaryActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
