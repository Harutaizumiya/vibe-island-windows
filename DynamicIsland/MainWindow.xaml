<Window x:Class="DynamicIsland.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="clr-namespace:DynamicIsland.UI"
        mc:Ignorable="d"
        Title="Dynamic Island"
        Width="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowWidth}"
        Height="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowHeight}"
        MinWidth="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowWidth}"
        MinHeight="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowHeight}"
        MaxWidth="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowWidth}"
        MaxHeight="{Binding Source={StaticResource IslandLayoutConfig}, Path=WindowHeight}"
        d:DesignWidth="520"
        d:DesignHeight="300"
        AllowsTransparency="True"
        Background="Transparent"
        BorderThickness="0"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="True"
        SizeToContent="Manual"
        Topmost="True"
        UseLayoutRounding="True"
        WindowStartupLocation="Manual"
        WindowStyle="None">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid x:Name="RootGrid"
          Background="Transparent"
          MouseLeftButtonDown="RootGrid_OnMouseLeftButtonDown">
        <!-- Main island shell. Adjust size values in App.xaml's IslandLayoutConfig resource. -->
        <Border x:Name="MainSurface"
                Width="{x:Static ui:IslandLayout.CollapsedWidth}"
                Height="{x:Static ui:IslandLayout.CollapsedHeight}"
                Padding="12,6"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                BorderThickness="1"
                ClipToBounds="True"
                MouseEnter="MainSurface_OnMouseEnter"
                MouseLeave="MainSurface_OnMouseLeave"
                RenderTransformOrigin="0.5,0">
            <Border.CornerRadius>
                <Binding Source="{StaticResource IslandLayoutConfig}"
                         Path="CollapsedShellCornerRadius" />
            </Border.CornerRadius>
            <Border.Margin>
                <Binding Source="{StaticResource IslandLayoutConfig}"
                         Path="TopMarginThickness" />
            </Border.Margin>
            <Border.Background>
                <SolidColorBrush x:Name="MainSurfaceBackgroundBrush"
                                 Color="#FF000000" />
            </Border.Background>
            <Border.BorderBrush>
                <SolidColorBrush x:Name="MainSurfaceBorderBrush"
                                 Color="#FF161616" />
            </Border.BorderBrush>
            <Border.RenderTransform>
                <ScaleTransform x:Name="IslandScaleTransform"
                                ScaleX="1"
                                ScaleY="1" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header row height follows IslandLayoutConfig for Hot Reload edits. -->
                    <RowDefinition Height="{Binding Source={StaticResource IslandLayoutConfig}, Path=StatusRowGridHeight}" />
                    <!-- Expanded content height is animated in MainWindow.xaml.cs -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid x:Name="StatusCard"
                      Grid.Row="0"
                      Margin="0,4,0,0"
                      MouseLeftButtonDown="StatusCard_OnMouseLeftButtonDown">
                    <Grid Margin="2,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="StatusContentTranslateTransform"
                                                Y="0" />
                        </Grid.RenderTransform>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="GlyphContainer"
                                Width="24"
                                Height="24"
                                VerticalAlignment="Top"
                                Margin="0,4,0,0"
                                CornerRadius="12"
                                Background="#FF0A0A0A"
                                BorderThickness="1">
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="GlyphBorderBrush"
                                                 Color="#FF181818" />
                            </Border.BorderBrush>
                            <Grid>
                                <Ellipse x:Name="StatusAccentEllipse"
                                         Width="18"
                                         Height="18"
                                         Opacity="0.14">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="StatusAccentEllipseBrush"
                                                         Color="#FF6CE1FF" />
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="StatusGlyphText"
                                           Text="{Binding StatusGlyph}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Cascadia Code SemiBold"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                            </Grid>
                        </Border>

                        <StackPanel x:Name="StatusTextPanel"
                                    Grid.Column="1"
                                    Margin="10,8,8,0"
                                    VerticalAlignment="Top">
                            <TextBlock x:Name="StatusTitleText"
                                       Text="{Binding StatusText}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13"
                                       LineHeight="16"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Top"
                                       TextTrimming="CharacterEllipsis" />
                            
                        </StackPanel>
                    </Grid>
                </Grid>

                <Grid x:Name="ExpandedRegion"
                      Grid.Row="1"
                      Height="0"
                      VerticalAlignment="Top"
                      ClipToBounds="True">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="ExpandedRegionTranslateTransform"
                                            Y="-10" />
                    </Grid.RenderTransform>

                    <!-- Expanded detail region sizing follows IslandLayoutConfig. -->
                    <Grid x:Name="ActionPanel"
                          MinHeight="{Binding Source={StaticResource IslandLayoutConfig}, Path=ActionPanelMinHeight}"
                          Opacity="0">
                        <Grid.Margin>
                            <Binding Source="{StaticResource IslandLayoutConfig}"
                                     Path="ExpandedRegionTopSpacingThickness" />
                        </Grid.Margin>
                        <Grid Margin="2,0,2,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel x:Name="ActionPanelHeader">
                                <TextBlock Text="CHANGED FILES"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"
                                           Opacity="0.9" />
                                <Border Padding="10,8"
                                        Margin="0,0,0,8"
                                        CornerRadius="12"
                                        Background="#14000000"
                                        BorderBrush="#22FFFFFF"
                                        BorderThickness="1">
                                    <ItemsControl x:Name="ChangedFilesList"
                                                  ItemsSource="{Binding ChangedFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontFamily="Cascadia Code"
                                                           Margin="0,0,0,4"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                                <TextBlock Text="{Binding PanelHintText}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <UniformGrid x:Name="ActionButtonsPanel"
                                         Grid.Row="1"
                                         Margin="0,0,0,0"
                                         Columns="3"
                                         Opacity="0">
                                <Button Command="{Binding PrimaryActionCommand}"
                                        Content="{Binding PrimaryActionText}"
                                        Style="{StaticResource AccentActionButtonStyle}"
                                        Visibility="{Binding IsPrimaryActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Command="{Binding SecondaryActionCommand}"
                                        Content="{Binding SecondaryActionText}"
                                        Style="{StaticResource SecondaryActionButtonStyle}"
                                        Visibility="{Binding IsSecondaryActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Button Command="{Binding TertiaryActionCommand}"
                                        Content="{Binding TertiaryActionText}"
                                        Style="{StaticResource TertiaryActionButtonStyle}"
                                        Visibility="{Binding IsTertiaryActionVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </UniformGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
